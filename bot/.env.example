# =========================================================================
# Marsexpress24 — environment variables
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# =========================================================================

# --- Telegram --------------------------------------------------------------
# Get from @BotFather
BOT_TOKEN=your_telegram_bot_token_here

# Admin's Telegram numeric user ID — receives order receipts.
# Find via @userinfobot
ADMIN_ID=123456789

# --- Mini App URL ----------------------------------------------------------
# Public HTTPS URL where /miniapp is hosted (e.g. https://yourdomain.com/miniapp).
# Used by the /start inline button to open the Web App.
WEBAPP_URL=https://yourdomain.com/miniapp

# --- Database --------------------------------------------------------------
DATABASE_URL=postgresql://user:password@localhost:5432/marsexpress24

# --- Server ----------------------------------------------------------------
PORT=3000
NODE_ENV=development

# --- Webhook (production only) --------------------------------------------
# Public HTTPS URL of THIS bot server (without trailing slash).
# Telegraf appends a secret path; the full webhook is `${WEBHOOK_DOMAIN}/telegraf/<secret>`.
# Leave empty in development — polling will be used instead.
WEBHOOK_DOMAIN=

# --- CORS ------------------------------------------------------------------
# Comma-separated list of allowed origins for the REST API.
# Telegram serves Mini Apps from web.telegram.org / *.t.me.
ALLOWED_ORIGINS=https://web.telegram.org,https://t.me
